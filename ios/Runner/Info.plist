<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>

	<!-- Basic App Info -->
	<key>CFBundleDevelopmentRegion</key>
	<string>$(DEVELOPMENT_LANGUAGE)</string>

	<key>CFBundleDisplayName</key>
	<string>TumiaX</string>

	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>

	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>

	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>

	<key>CFBundleName</key>
	<string>tumiax_frontend</string>

	<key>CFBundlePackageType</key>
	<string>APPL</string>

	<key>CFBundleShortVersionString</key>
	<string>$(FLUTTER_BUILD_NAME)</string>

	<key>CFBundleSignature</key>
	<string>????</string>

	<key>CFBundleVersion</key>
	<string>$(FLUTTER_BUILD_NUMBER)</string>

	<key>LSRequiresIPhoneOS</key>
	<true/>

	<!-- Launch -->
	<key>UILaunchStoryboardName</key>
	<string>LaunchScreen</string>

	<key>UIMainStoryboardFile</key>
	<string>Main</string>

	<!-- Orientation -->
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
	</array>

	<key>UISupportedInterfaceOrientations~ipad</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationPortraitUpsideDown</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>

	<!-- Performance -->
	<key>CADisableMinimumFrameDurationOnPhone</key>
	<true/>

	<key>UIApplicationSupportsIndirectInputEvents</key>
	<true/>

	<!-- Camera -->
	<key>NSCameraUsageDescription</key>
	<string>TumiaX uses the camera for identity verification (KYC), QR scanning, and verifying assets uploaded to the platform.</string>

	<!-- Photo Library -->
	<key>NSPhotoLibraryUsageDescription</key>
	<string>TumiaX uses your photo library so you can upload asset photos, identity documents, and verification images.</string>

	<key>NSPhotoLibraryAddUsageDescription</key>
	<string>TumiaX may save generated or verified asset images to your device.</string>

	<!-- Microphone -->
	<key>NSMicrophoneUsageDescription</key>
	<string>TumiaX may use microphone access when recording verification videos.</string>

	<!-- Location -->
	<key>NSLocationWhenInUseUsageDescription</key>
	<string>TumiaX uses your location to verify asset locations, improve security, and support location-based asset validation.</string>

	<key>NSLocationAlwaysAndWhenInUseUsageDescription</key>
	<string>TumiaX uses your location for secure asset verification and fraud prevention.</string>

	<key>NSLocationAlwaysUsageDescription</key>
	<string>TumiaX uses location services to verify physical asset locations and enhance account security.</string>

	<!-- Biometrics -->
	<key>NSFaceIDUsageDescription</key>
	<string>TumiaX uses Face ID for secure account authentication and verification.</string>

	<!-- URL Launcher -->
	<key>LSApplicationQueriesSchemes</key>
	<array>
		<string>https</string>
		<string>http</string>
		<string>mailto</string>
		<string>tel</string>
	</array>

	<!-- Encryption -->
	<key>ITSAppUsesNonExemptEncryption</key>
	<false/>

	<!-- Status Bar -->
	<key>UIStatusBarHidden</key>
	<false/>

	<key>UIViewControllerBasedStatusBarAppearance</key>
	<false/>

</dict>
</plist>